--- !u!114 &1461582495
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1461582490}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 21c58ebed6a8b304bbd5737f7bdb4807, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  lines:
  - speakerName: Commander
    portrait: {fileID: 0}
    text: "Alright\u2026 you\u2019re in."
    choices: []
    nextLineIndex: 0
  - speakerName: Commander
    portrait: {fileID: 0}
    text: "This warehouse isn\u2019t abandoned. It\u2019s their hideout. They\u2019ve
      been using it to lay low."
    choices: []
    nextLineIndex: 1
  - speakerName: Commander
    portrait: {fileID: 0}
    text: "Stay sharp. If they\u2019re hiding here, they won\u2019t be far."
    choices: []
    nextLineIndex: 2
  - speakerName: Commander
    portrait: {fileID: 0}
    text: Your mission is to get the briefcase back. They stole it from us.
    choices: []
    nextLineIndex: 3
  - speakerName: Commander
    portrait: {fileID: 0}
    text: "It has important information inside. We can\u2019t let them keep it."
    choices: []
    nextLineIndex: 4
  - speakerName: Commander
    portrait: {fileID: 0}
    text: Look around. See if anything stands out.
    choices: []
    nextLineIndex: 5
  - speakerName: Commander
    portrait: {fileID: 0}
    text: They had to stash it somewhere.
    choices: []
    nextLineIndex: -1
